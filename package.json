{
	"name": "clipilot",
	"version": "0.1.0",
	"description": "TUI meta-orchestrator that commands coding agents via tmux",
	"type": "module",
	"bin": {
		"clipilot": "./dist/main.js"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"start": "node dist/main.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "biome check src/",
		"format": "biome format --write src/"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.39.0",
		"better-sqlite3": "^11.8.1",
		"chalk": "^5.4.1",
		"chokidar": "^4.0.3",
		"express": "^5.2.1",
		"node-llama-cpp": "^3.16.2",
		"sqlite-vec": "^0.1.6",
		"ws": "^8.19.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.5",
		"@types/better-sqlite3": "^7.6.12",
		"@types/express": "^5.0.6",
		"@types/node": "^22.0.0",
		"@types/ws": "^8.18.1",
		"typescript": "^5.9.2",
		"vitest": "^3.2.4"
	}
}
